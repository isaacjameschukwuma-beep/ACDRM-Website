# Normalise line endings so the repo is consistent across Windows / Linux (Vercel)
* text=auto eol=lf

# Treat these as binary (no EOL conversion, no diff)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.mp4  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
